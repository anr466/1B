# ==================== البيئة ====================
ENVIRONMENT=production
DEBUG=False

# ==================== قاعدة البيانات ====================
DATABASE_PATH=database/trading_database.db
DATABASE_TIMEOUT=30

# ==================== المصادقة والأمان ====================
# JWT Secret - استخدم قيمة قوية جداً
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ==================== التشفير ====================
# Fernet Key - استخدم Fernet.generate_key() لإنشاء مفتاح جديد
ENCRYPTION_KEY=your-fernet-encryption-key-change-this-in-production

# ==================== Binance API ====================
# لا تضع مفاتيح Binance الحقيقية هنا - استخدم قاعدة البيانات فقط
BINANCE_API_BASE_URL=https://api.binance.com
# مفاتيح الخلفية للنظام - استخدم sandbox keys للتطوير
BINANCE_BACKEND_API_KEY=your-binance-api-key-here
BINANCE_BACKEND_API_SECRET=your-binance-api-secret-here

# ==================== Rate Limiting ====================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# ==================== البصمة البيومترية ====================
BIOMETRIC_AUTH_ENABLED=True
BIOMETRIC_HASH_ALGORITHM=sha256
BIOMETRIC_TIMEOUT_SECONDS=300

# ==================== البريد الإلكتروني ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@tradingbot.com

# ==================== الخادم ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=3002
SERVER_WORKERS=4

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# ==================== السجلات ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# ==================== المراقبة ====================
MONITORING_ENABLED=False

# ==================== Firebase Push Notifications ====================
FIREBASE_CREDENTIALS_PATH=config/security/firebase-service-account.json
FIREBASE_ENABLED=True
METRICS_PORT=9090

# ==================== المنافذ الإضافية ====================
METRO_PORT=8081
NGROK_ENABLED=False

# ==================== البريد الإلكتروني ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@yourapp.com
SMTP_ENABLED=True
