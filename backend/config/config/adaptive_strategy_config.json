{
  "strategy_weights": {
    "breakout": 0.2,
    "mean_reversion": 0.15,
    "volume_surge": 0.2,
    "swing_scalp": 0.15,
    "support_bounce": 0.15,
    "channel_trading": 0.15
  },
  "market_analysis": {
    "volatility_threshold": 0.02,
    "volume_threshold": 1.5,
    "trend_strength_threshold": 0.6,
    "support_resistance_threshold": 0.8
  },
  "adaptation_rules": {
    "high_volatility": {
      "preferred_strategies": ["breakout", "volume_surge"],
      "weight_multiplier": 1.5
    },
    "low_volatility": {
      "preferred_strategies": ["mean_reversion", "channel_trading"],
      "weight_multiplier": 1.3
    },
    "trending_market": {
      "preferred_strategies": ["breakout", "swing_scalp"],
      "weight_multiplier": 1.4
    },
    "sideways_market": {
      "preferred_strategies": ["mean_reversion", "channel_trading", "support_bounce"],
      "weight_multiplier": 1.2
    }
  },
  "optimization_settings": {
    "grid_search_enabled": true,
    "random_search_enabled": true,
    "max_iterations": 100,
    "optimization_metric": "total_return",
    "cross_validation_folds": 5
  },
  "ensemble_settings": {
    "min_strategies": 2,
    "max_strategies": 4,
    "voting_method": "weighted",
    "confidence_threshold": 0.7
  },
  "performance_tracking": {
    "lookback_period": 30,
    "min_trades_for_evaluation": 10,
    "performance_decay_factor": 0.95,
    "rebalance_frequency": "weekly"
  },
  "risk_management": {
    "max_correlation": 0.8,
    "max_drawdown_threshold": 0.15,
    "position_size_adjustment": true,
    "dynamic_stop_loss": true
  },
  "data_requirements": {
    "min_data_points": 100,
    "required_timeframes": ["1h", "4h", "1d"],
    "data_quality_threshold": 0.95
  }
}
