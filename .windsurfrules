### 4.2 Defensive Programming (أمثلة مكثفة)

```python
# ═══════════════════════════════════════════
# INPUT VALIDATION
# ═══════════════════════════════════════════
def process(data):
    # Type + Presence + Value checks
    if not isinstance(data, dict):
        raise TypeError(f"Expected dict, got {type(data)}")
    if 'field' not in data or not data['field']:
        raise ValueError("Missing/empty field")
    return data['field'].upper()

# ═══════════════════════════════════════════
# ERROR HANDLING
# ═══════════════════════════════════════════
# Level 1: Fail Fast
if amount <= 0:
    raise ValueError(f"Invalid amount: {amount}")

# Level 2: Graceful Degradation
try:
    recommendations = service.get(user_id)
except ServiceError:
    recommendations = []  # Degrade, don't fail

# Level 3: Retry with Backoff
@retry(max_attempts=3, backoff=2)
def call_api():
    return requests.get(url).json()

# Level 4: Circuit Breaker
circuit = CircuitBreaker()
circuit.call(risky_function)

# ═══════════════════════════════════════════
# RESOURCE MANAGEMENT
# ═══════════════════════════════════════════
# Always use context managers
with get_db_connection() as conn:
    conn.execute("INSERT ...")
    # Auto-commit or rollback

# ═══════════════════════════════════════════
# DATABASE BEST PRACTICES
# ═══════════════════════════════════════════
# Prevent N+1
posts = db.query("SELECT * FROM posts JOIN users...")

# Prevent SQL Injection
db.query("SELECT * FROM users WHERE email = ?", (email,))

# Use indexes
CREATE INDEX idx_users_email ON users(email);

# ═══════════════════════════════════════════
# API DESIGN BEST PRACTICES
# ═══════════════════════════════════════════
# Idempotent endpoints
@app.post("/api/orders")
def create_order():
    order_id = request.json.get('order_id')
    existing = Order.get(order_id)
    if existing:
        return existing, 200  # Already created
    return Order.create(request.json), 201

# Auth + Rate Limiting
@app.get("/api/data")
@require_auth
@rate_limit("10/minute")
def get_data():
    return {"data": [...]}
