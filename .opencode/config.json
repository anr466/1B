{
  "$schema": "https://opencode.ai/schema/config.json",
  "version": "1.3.13",
  "project": {
    "name": "Trading Bot System",
    "type": "flutter-fastapi",
    "description": "Flutter Mobile App + Python FastAPI Backend + PostgreSQL Trading System"
  },
  "skills": {
    "directory": "/Users/anr/.agents/skills",
    "auto_load": true,
    "categories": [
      "brainstorming",
      "planning",
      "implementation",
      "testing",
      "debugging",
      "security",
      "refactoring",
      "documentation",
      "flutter",
      "python",
      "fastapi",
      "postgresql",
      "trading"
    ],
    "relevant_skills": [
      "@brainstorming",
      "@test-driven-development",
      "@debugging-strategies",
      "@security-auditor",
      "@lint-and-validate",
      "@frontend-design",
      "@api-design-principles",
      "@create-pr",
      "@planning",
      "@implementation",
      "@review",
      "@refactoring",
      "@testing",
      "@documentation",
      "@flutter-best-practices",
      "@dart-performance",
      "@python-best-practices",
      "@fastapi-patterns",
      "@async-python",
      "@database-patterns",
      "@trading-strategy-engine",
      "@backtest-framework",
      "@risk-management",
      "@market-analysis",
      "@flutter-trading-ui",
      "@master-patterns"
    ],
    "auto_load_rules": [
      {
        "trigger": "strategy OR strategy design OR trading strategy OR entry exit",
        "skill": "trading-strategy-engine"
      },
      {
        "trigger": "backtest OR back test OR historical test OR walk forward",
        "skill": "backtest-framework"
      },
      {
        "trigger": "risk management OR position size OR stop loss OR drawdown OR kelly",
        "skill": "risk-management"
      },
      {
        "trigger": "market analysis OR regime detection OR technical indicator OR RSI OR MACD OR ADX",
        "skill": "market-analysis"
      },
      {
        "trigger": ".dart OR flutter OR widget OR UI OR layout OR theme OR design",
        "skill": "flutter-trading-ui"
      },
      {
        "trigger": "architecture OR pattern OR bootstrap OR session OR state management",
        "skill": "master-patterns"
      }
    ]
  },
  "context": {
    "files": [
      "AGENTS.md",
      "CLAUDE.md",
      ".windsurfrules",
      ".TRADING_BOT_SYSTEM_DESIGN_v1.2.md"
    ],
    "auto_inject": {
      "dart": true,
      "python": true,
      "yaml": true,
      "json": true
    }
  },
  "agents": {
    "default": "sisyphus",
    "available": [
      "sisyphus",
      "hephaestus",
      "prometheus",
      "oracle",
      "artistry",
      "ultrabrain",
      "deep",
      "quick"
    ]
  },
  "mcp": {
    "enabled": true,
    "servers": [
      {
        "name": "playwright",
        "command": "npx",
        "args": ["-y", "@playwright/mcp"],
        "env": {}
      },
      {
        "name": "dart-mcp-server",
        "type": "local",
        "command": ["dart", "mcp-server"],
        "enabled": true,
        "environment": {}
      }
    ]
  },
  "rules": {
    "mandatory": [
      "Read AGENTS.md before any work",
      "Read CLAUDE.md before any implementation",
      "Minimum 3 issues per code review",
      "All tests must pass before commit",
      "No mock data in production code",
      "When working on any Flutter or Dart file (.dart), automatically load the ui-ux-pro-max skill and connect to dart-mcp-server before proceeding"
    ],
    "workflows": [
      "ANALYZE → PLAN → EXECUTE → TEST → COMMIT",
      "ULTRAWORK mode for complex tasks",
      "Coverage check before planning"
    ]
  }
}