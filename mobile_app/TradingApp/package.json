{
  "name": "trading-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "npx @react-native-community/cli run-android",
    "ios": "npx @react-native-community/cli run-ios",
    "lint": "eslint .",
    "start": "npx metro serve --host 0.0.0.0 --port 8081",
    "test": "jest",
    "test:visual-regression": "jest --testPathPattern=visual-regression --verbose",
    "test:visual": "npm run test:visual-regression",
    "clean": "npx react-native clean",
    "reset-cache": "npx metro serve --host 0.0.0.0 --port 8081 --reset-cache",
    "setup-usb": "./setup-usb-connection.sh",
    "dev": "./start-dev.sh",
    "adb-setup": "adb reverse tcp:3002 tcp:3002 && adb reverse tcp:8081 tcp:8081 && adb reverse --list"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-community/slider": "^5.1.1",
    "@react-native-firebase/app": "^18.3.0",
    "@react-native-firebase/auth": "^18.3.0",
    "@react-native-firebase/messaging": "^18.3.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "react": "18.2.0",
    "react-native": "0.72.17",
    "react-native-biometrics": "^3.0.1",
    "react-native-chart-kit": "^6.12.0",
    "react-native-device-info": "^10.14.0",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "2.12.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-safe-area-context": "4.7.4",
    "react-native-screens": "3.25.0",
    "react-native-svg": "^13.14.0",
    "react-native-vector-icons": "^10.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/runtime": "^7.20.0",
    "@react-native-community/cli": "12.3.6",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "babel-jest": "^29.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.7.0",
    "metro": "^0.83.1",
    "metro-react-native-babel-preset": "0.77.0",
    "prettier": "^2.4.1",
    "react-test-renderer": "^18.2.0"
  },
  "engines": {
    "node": ">=16"
  }
}
