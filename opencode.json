{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "docker": {
      "type": "local",
      "command": ["npx", "-y", "docker-mcp"]
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "-y", "mcp-server-fetch-typescript"]
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/anr/Desktop/trading_ai_bot-1"]
    },
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "mcp-postgres-server"],
      "environment": {
        "PG_HOST": "localhost",
        "PG_PORT": "5432",
        "PG_USER": "trading_user",
        "PG_PASSWORD": "change-this-password",
        "PG_DATABASE": "trading_ai_bot"
      }
    },
    "python": {
      "type": "local",
      "command": ["uvx", "mcp-python"]
    }
  }
}
