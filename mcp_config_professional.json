{
  "mcpServers": {
    "deepwiki": {
      "headers": {},
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "figma-remote-mcp-server": {
      "headers": {},
      "serverUrl": "https://mcp.figma.com/mcp"
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        ""
      ],
      "command": "npx",
      "env": {}
    },
    "github": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "command": "npx",
      "env": {
        "GITHUB_TOKEN": "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"
      }
    },
    "react-native-mcp": {
      "args": [
        "-y",
        "@divagnz/mcp-react-native-expo"
      ],
      "command": "npx",
      "env": {}
    },
    "magic-ui": {
      "args": [
        "-y",
        "@magicuidesign/mcp"
      ],
      "command": "npx",
      "env": {}
    },
    "semgrep": {
      "args": [
        "-y",
        "@semgrep/mcp"
      ],
      "command": "npx",
      "env": {
        "SEMGREP_API_TOKEN": ""
      }
    },
    "mcp-playwright": {
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "command": "npx",
      "env": {}
    },
    "puppeteer": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "command": "npx",
      "env": {}
    },
    "sequential-thinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx",
      "env": {}
    },
    "time": {
      "args": [
        "-m",
        "mcp_server_time"
      ],
      "command": "python",
      "disabled": false,
      "env": {}
    },
    "mcp-toolbox": {
      "args": [
        "-y",
        "mcp-toolbox"
      ],
      "command": "npx",
      "env": {
        "FIGMA_API_KEY": "",
        "TAVILY_API_KEY": "",
        "DUCKDUCKGO_API_KEY": "",
        "BFL_API_KEY": ""
      }
    },
    "chrome-devtools": {
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=true",
        "--isolated=true",
        "--executablePath=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
      ],
      "command": "npx",
      "env": {}
    },
    "chrome-devtools-android": {
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://127.0.0.1:9222"
      ],
      "command": "npx",
      "env": {}
    }
  }
}